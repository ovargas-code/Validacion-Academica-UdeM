# ================================================================
# ARCHIVO DE EJEMPLO - Copia este archivo a ".env"
# NUNCA subas el archivo ".env" real a Git
# ================================================================

# Seguridad del portal web
ADMIN_USER=admin
ADMIN_PASSWORD=udem2026

# JWT — OBLIGATORIO en producción: cambia el secret por uno aleatorio de al menos 32 caracteres
# Genera uno seguro con: openssl rand -base64 48
JWT_SECRET=changeme-replace-in-production-min32chars!
JWT_EXPIRATION_MS=3600000

# CORS — orígenes permitidos para el frontend (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# H2 Console — solo activar en desarrollo local
H2_CONSOLE_ENABLED=true

# Puerto de la aplicación local
SERVER_PORT=8081

# Base de datos PostgreSQL (solo cuando arranques con --spring.profiles.active=postgres)
DB_URL=jdbc:postgresql://localhost:5432/validacion_academica
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Correo SMTP / Gmail
# Recomendado para Gmail: puerto 587 con STARTTLS y contraseña de aplicación.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=su_correo@gmail.com
MAIL_PASSWORD=su_app_password
MAIL_STARTTLS_ENABLE=true
MAIL_STARTTLS_REQUIRED=false
MAIL_SSL_ENABLE=false
MAIL_DEBUG=true
